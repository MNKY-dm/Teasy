<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0" styleClass="home-pane" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SeanceController">

   <top>
      <VBox alignment="TOP_CENTER">
         <fx:include source="MenuBar.fxml" />
         <VBox alignment="CENTER" spacing="6.0">
            <padding>
               <Insets bottom="8.0" top="12.0" />
            </padding>

            <Label fx:id="eventTitle" styleClass="page-title" />
            <Label styleClass="section-label" text="Acheter un ticket" />
         </VBox>
      </VBox>
   </top>

   <center>
      <VBox alignment="CENTER" styleClass="home-content">
         <GridPane alignment="CENTER" hgap="12.0" vgap="12.0">
            <columnConstraints>
               <ColumnConstraints halignment="RIGHT" minWidth="170.0" prefWidth="170.0" />
               <ColumnConstraints halignment="LEFT" minWidth="190.0" prefWidth="190.0" />
               <ColumnConstraints halignment="LEFT" minWidth="190.0" prefWidth="190.0" />
            </columnConstraints>

            <Label styleClass="stat-label" text="Catégorie STANDARD :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="0" />

            <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.rowIndex="0">
               <Label fx:id="labelPrice1" styleClass="label-price" />
               <Label layoutX="199.0" layoutY="22.0" styleClass="label-price" text="€" />

            </HBox>
            <Spinner fx:id="spinnerNbTickets1" prefWidth="110.0" styleClass="form-spinner" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="0" />

            <Label styleClass="stat-label" text="Catégorie PLUS :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="1" />

            <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.rowIndex="1">
               <Label fx:id="labelPrice2" styleClass="label-price" />
               <Label layoutX="199.0" layoutY="126.0" styleClass="label-price" text="€" />

            </HBox>
            <Spinner fx:id="spinnerNbTickets2" prefWidth="110.0" styleClass="form-spinner" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="1" />

            <Label styleClass="stat-label" text="Catégorie VIP :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="2" />

            <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.rowIndex="2">
               <Label fx:id="labelPrice3" styleClass="label-price" />
               <Label layoutX="179.0" layoutY="22.0" styleClass="label-price" text="€" />

            </HBox>
            <Spinner fx:id="spinnerNbTickets3" prefWidth="110.0" styleClass="form-spinner" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="2" />
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
         </GridPane>
      </VBox>
   </center>

   <bottom>
      <HBox alignment="CENTER" spacing="12.0">
         <padding>
            <Insets bottom="16.0" top="8.0" />
         </padding>

         <Button mnemonicParsing="false" onAction="#buyTickets" styleClass="btn-primary" text="Acheter" />

         <Button mnemonicParsing="false" onAction="#returnToEvent" styleClass="btn-secondary" text="Retourner à l'événement" />
      </HBox>
   </bottom>

   <padding>
      <Insets bottom="6.0" left="6.0" right="6.0" />
   </padding>
</BorderPane>
