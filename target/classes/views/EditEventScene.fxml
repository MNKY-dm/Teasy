<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<BorderPane styleClass="home-pane" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EditEventController">
    <!-- HAUT : MenuBar + titre -->
    <top>
        <VBox alignment="TOP_CENTER">
            <fx:include source="MenuBar.fxml" />
            <Label styleClass="section-label" text="Modification d'événement" />
            <VBox.margin><Insets bottom="8.0" top="12.0" /></VBox.margin>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" BorderPane.alignment="TOP_CENTER">
            <content>
                <VBox alignment="TOP_CENTER" spacing="16.0" styleClass="home-content">
                    <GridPane alignment="TOP_CENTER" hgap="12.0" vgap="12.0">
                        <Label styleClass="stat-label" text="Nom :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="eventName" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label styleClass="stat-label" text="Description :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="eventDescription" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label styleClass="stat-label" text="URL de l'affiche :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="eventAfficheUrl" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label styleClass="stat-label" text="Aperçu de l'affiche :" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <ImageView fx:id="eventAffiche" GridPane.columnIndex="1" GridPane.rowIndex="3" fitHeight="240.0" fitWidth="240.0" />
                        <Label styleClass="stat-label" text="Langue :" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField fx:id="eventLanguage" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <Label styleClass="stat-label" text="Créateur :" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <TextField fx:id="eventCreator" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="5" editable="false" />
                        <Label styleClass="stat-label" text="ID du créateur :" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                        <TextField fx:id="eventCreatorId" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="6" onKeyReleased="#updateCreatorPreview" />
                        <columnConstraints>
                            <ColumnConstraints />
                            <ColumnConstraints />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>
                    </GridPane>
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="16.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
    <padding>
        <Insets bottom="6.0" left="6.0" right="6.0" />
    </padding>
    <bottom>
        <HBox alignment="TOP_CENTER" spacing="12.0">
            <Button fx:id="saveEventBtn" mnemonicParsing="false" onAction="#saveEvent" styleClass="btn-primary" text="Enregistrer" />
            <Button mnemonicParsing="false" onAction="#moveToMyEvents" styleClass="btn-secondary" text="Retour à l'accueil" />
        </HBox>
    </bottom>
</BorderPane>
