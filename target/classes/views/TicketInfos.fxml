<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefWidth="600.0" spacing="8.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TicketInfosController">
    <children>
        <Label fx:id="ticketID" />
        <Label fx:id="eventName" />
        <Label fx:id="userName" />
        <Label fx:id="ticketType" />
        <Label fx:id="seanceID" />
        <Label fx:id="seanceLocation" />
        <Label fx:id="seanceDate" />
        <Label fx:id="price" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="ticketStatus" alignment="CENTER_RIGHT" contentDisplay="RIGHT" />
    </children>
    <padding>
        <Insets left="6.0" right="6.0" />
    </padding>

</HBox>
