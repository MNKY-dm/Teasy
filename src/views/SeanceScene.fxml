<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            styleClass="seance-pane"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SeanceController">
   <children>
      <fx:include source="MenuBar.fxml" />
      <Label fx:id="eventTitle" layoutX="300.0" layoutY="25.0"
             styleClass="event-title-label" />
      <Label layoutX="14.0" layoutY="70.0" text="Acheter un ticket"
             styleClass="section-title" />
      <Label layoutX="14.0"  layoutY="97.0"  text="Catégorie 1 : " styleClass="label-category" />
      <Label fx:id="labelPrice1" layoutX="92.0" layoutY="97.0"     styleClass="label-price" />
      <Spinner fx:id="spinnerNbTickets1" layoutX="130.0" layoutY="94.0" prefHeight="5.0" prefWidth="63.0" />
      <Label layoutX="14.0"  layoutY="127.0" text="Catégorie 2 : " styleClass="label-category" />
      <Label fx:id="labelPrice2" layoutX="92.0" layoutY="127.0"    styleClass="label-price" />
      <Spinner fx:id="spinnerNbTickets2" layoutX="130.0" layoutY="123.0" prefHeight="5.0" prefWidth="63.0" />
      <Label layoutX="14.0"  layoutY="157.0" text="Catégorie Or : " styleClass="label-category" />
      <Label fx:id="labelPrice3" layoutX="100.0" layoutY="156.0"   styleClass="label-price" />
      <Spinner fx:id="spinnerNbTickets3" layoutX="130.0" layoutY="153.0" prefHeight="5.0" prefWidth="63.0" />
      <Button layoutX="14.0" layoutY="200.0" mnemonicParsing="false"
              onAction="#buyTickets" text="Acheter" styleClass="btn-primary" />
      <Button layoutX="26.0" layoutY="353.0" mnemonicParsing="false"
              onAction="#returnToEvent" text="Retourner à l'événement"
              styleClass="btn-secondary" />
   </children>
</AnchorPane>