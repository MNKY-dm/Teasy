<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="home-pane" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminPanelController">

    <!-- HAUT : MenuBar + titre -->
    <top>
        <VBox>
            <fx:include source="MenuBar.fxml" />
            <Label alignment="CENTER" maxWidth="Infinity" styleClass="page-title" text="Panel Admin">
                <VBox.margin><Insets bottom="8.0" top="12.0" /></VBox.margin>
            </Label>
        </VBox>
    </top>

    <!-- CENTRE : stats -->
    <center>
        <VBox spacing="16.0">
            <VBox.margin><Insets left="24.0" right="24.0" top="16.0" /></VBox.margin>

            <!-- Bloc tickets par type -->
            <VBox spacing="8.0">
                <Label styleClass="section-label" text="Nombre de tickets :" />

                <HBox spacing="24.0">
                    <HBox spacing="6.0">
                        <Label styleClass="stat-label" text="Standard :" />
                        <Label fx:id="nbStandardTickets" styleClass="stat-value" />
                    </HBox>
                    <HBox spacing="6.0">
                        <Label styleClass="stat-label" text="Plus :" />
                        <Label fx:id="nbPlusTickets" styleClass="stat-value" />
                    </HBox>
                    <HBox spacing="6.0">
                        <Label styleClass="stat-label" text="VIP :" />
                        <Label fx:id="nbVIPTickets" styleClass="stat-value" />
                    </HBox>
                    <HBox spacing="6.0">
                        <Label styleClass="stat-label" text="Total :" />
                        <Label fx:id="nbTotalTickets" styleClass="stat-value" />
                    </HBox>
                </HBox>
            </VBox>

            <!-- Ligne : tickets valides -->
            <HBox spacing="8.0">
                <Label styleClass="stat-label" text="Nombre de tickets valides :" />
                <Label fx:id="nbValidTickets" styleClass="stat-value" />
            </HBox>

            <!-- Ligne : tickets périmés -->
            <HBox spacing="8.0">
                <Label styleClass="stat-label" text="Nombre de tickets périmés :" />
                <Label fx:id="nbExpiredTickets" styleClass="stat-value" />
            </HBox>

            <!-- Ligne : tickets remboursés -->
            <HBox spacing="8.0">
                <Label styleClass="stat-label" text="Nombre de tickets remboursés :" />
                <Label fx:id="nbRefundedTickets" styleClass="stat-value" />
            </HBox>

        </VBox>
    </center>
   <padding>
      <Insets bottom="6.0" left="6.0" right="6.0" />
   </padding>
   <bottom>
      <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#toTicketsManagement" styleClass="btn-primary" text="Gérer les tickets" textAlignment="CENTER" BorderPane.alignment="CENTER" />
   </bottom>

</BorderPane>
