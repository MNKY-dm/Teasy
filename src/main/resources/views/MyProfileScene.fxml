<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="home-pane" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MyProfileController">

    <!-- HAUT : MenuBar + titre -->
    <top>
        <VBox alignment="TOP_CENTER">
            <fx:include source="MenuBar.fxml" />
            <Label styleClass="section-label" text="Mon profil" />
            <VBox.margin><Insets bottom="8.0" top="12.0" /></VBox.margin>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" BorderPane.alignment="TOP_CENTER">
            <content>
                <VBox alignment="TOP_CENTER" spacing="16.0" styleClass="home-content">

                    <GridPane alignment="TOP_CENTER" hgap="12.0" vgap="12.0">

                        <Label styleClass="stat-label" text="ID : " GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="userId" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="0" editable="false" />

                        <Label styleClass="stat-label" text="Nom : " GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="userName" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label styleClass="stat-label" text="Adresse mail :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="userEmail" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label styleClass="stat-label" text="Numéro de téléphone :" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="userTel" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label styleClass="stat-label" text="Compte :" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField fx:id="userRole" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="4" editable="false" />

                        <Label styleClass="stat-label" text="Compte créé le :" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <TextField fx:id="userCreatedAt" styleClass="auth-field" GridPane.columnIndex="1" GridPane.rowIndex="5" editable="false" />

                        <columnConstraints>
                            <ColumnConstraints />
                            <ColumnConstraints />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>

                    </GridPane>
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="16.0" />
                    </padding>


                </VBox>
            </content>
        </ScrollPane>
    </center>

    <padding>
        <Insets bottom="6.0" left="6.0" right="6.0" />
    </padding>
    <bottom>
        <HBox alignment="TOP_CENTER" spacing="12.0">
            <Button mnemonicParsing="false" onAction="#saveProfile" styleClass="btn-primary" text="Enregistrer" />
<!--            <Button layoutX="156.0" layoutY="10.0" mnemonicParsing="false" onAction="#deleteTicket" styleClass="btn-delete" text="Supprimer" />-->
            <Button mnemonicParsing="false" onAction="#moveToHome" styleClass="btn-secondary" text="Retour à l'accueil" />
        </HBox>
    </bottom>

</BorderPane>
